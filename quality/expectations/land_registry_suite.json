{
  "expectation_suite_name": "land_registry_suite",
  "ge_cloud_id": null,
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "transaction_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "transaction_id" },
      "meta": { "notes": "Every transaction must have a unique ID" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "transaction_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "price" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "price",
        "min_value": 1,
        "max_value": 100000000,
        "mostly": 0.999
      },
      "meta": { "notes": "Prices above £100m flagged but not failed — genuine ultra-prime sales exist" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "transaction_date" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "transaction_date",
        "min_value": "1995-01-01",
        "max_value": "2030-12-31"
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "property_type",
        "value_set": ["D", "S", "T", "F", "O"]
      },
      "meta": { "notes": "D=Detached, S=Semi, T=Terraced, F=Flat, O=Other" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "county" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "record_status",
        "value_set": ["A", "C", "D"]
      },
      "meta": { "notes": "A=Addition, C=Change, D=Delete" }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1000,
        "max_value": 2000000
      },
      "meta": { "notes": "Yearly file should have between ~800k and ~1.5m rows" }
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.0"
  }
}
