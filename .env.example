# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west2
GCS_BUCKET=uk-housing-pipeline-raw

# Service account key path (local dev only — never commit the real file)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-sa-key.json

# BigQuery datasets (created by Terraform)
BQ_RAW_DATASET=raw
BQ_STAGING_DATASET=staging
BQ_MARTS_DATASET=marts

# Pub/Sub (Phase 4)
PUBSUB_RATE_CHANGES_TOPIC=boe-rate-changes

# Land Registry
LAND_REGISTRY_YEAR=2025
